<!-- import event_system from event_system.xml -->
<module name="event_a" export="function:can_phase_2_fn,can_phase_3_fn,register_by_map,register_direct">
  <enum name="Phase">
    <member name="P2"/>
    <member name="P3"/>
  </enum>

  <const name="condition_map" type="#{event_a.Phase=>function}">#{
    event_a.Phase.P2: *can_phase_2_fn,
    event_a.Phase.P3: *can_phase_3_fn
  }</const>

  <function name="can_phase_2_fn" return_type="boolean">
    return false;
  </function>

  <function name="can_phase_3_fn" return_type="boolean">
    return true;
  </function>

  <function name="register_by_map" return_type="boolean">
    return event_system.set_condition(condition_map[event_a.Phase.P2]);
  </function>

  <function name="register_direct" return_type="boolean">
    return event_system.set_condition(*can_phase_3_fn);
  </function>
</module>
