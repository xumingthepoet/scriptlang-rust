<!-- import actors from actors.xml -->
<!-- import battle_loop from battle-loop.xml -->
<!-- import victory from victory.xml -->
<!-- import defeat from defeat.xml -->
<module name="main" export="script:main">
  <script name="main">
    <temp name="player" type="actors.Combatant">#{name: "Hero", hp: 12}</temp>
    <temp name="enemy" type="actors.Combatant">#{name: "Bandit", hp: 12}</temp>

    <text>Battle start: ${player.name}(${player.hp}) vs ${enemy.name}(${enemy.hp})</text>
    <text>Tip: if you keep using weak attacks, you will lose.</text>

    <call script="@battle_loop.battle_loop" args="ref:player,ref:enemy"/>

    <if when="player.hp > 0 AND enemy.hp LTE 0">
      <text>Result: ${player.name} wins. hp=${player.hp}</text>
      <goto script="@victory.victory"/>
      <else>
        <text>Result: ${enemy.name} wins. hp=${enemy.hp}</text>
        <goto script="@defeat.defeat"/>
      </else>
    </if>
  </script>
</module>
