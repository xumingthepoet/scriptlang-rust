<!-- import actors from actors.xml -->
<module name="battle-loop" export="script:battle-loop">
  <script name="battle-loop" kind="call" args="ref:actors.Combatant:player,ref:actors.Combatant:enemy">
    <temp name="potions" type="int">1</temp>
    <temp name="rounds" type="int">0</temp>

    <while when="player.hp > 0 AND enemy.hp > 0">
      <code>rounds = rounds + 1;</code>
      <text>== Round ${rounds} ==</text>
      <text>${player.name} hp=${player.hp}, ${enemy.name} hp=${enemy.hp}, potions=${potions}</text>

      <choice text="Choose">
        <option text="Heavy Slash (4 dmg)">
          <temp name="damage" type="int">4</temp>
          <text>You use Heavy Slash for ${damage}.</text>
          <code>enemy.hp = enemy.hp - damage;</code>
        </option>

        <option text="Quick Jab (1 dmg)">
          <temp name="damage" type="int">1</temp>
          <text>You use Quick Jab for ${damage}.</text>
          <code>enemy.hp = enemy.hp - damage;</code>
        </option>

        <option text="Drink Potion (+3 hp)" when="potions > 0">
          <temp name="heal" type="int">3</temp>
          <code>potions = potions - 1;</code>
          <code>player.hp = player.hp + heal;</code>
          <text>You drink a potion and recover ${heal}. hp=${player.hp}, potions=${potions}</text>
        </option>
      </choice>

      <if when="enemy.hp LTE 0">
        <text>${enemy.name} is down.</text>
        <else>
          <temp name="enemyAttackRoll" type="int">(rounds + player.hp + enemy.hp) % 3</temp>
          <if when="enemyAttackRoll == 0">
            <temp name="enemyDamage" type="int">3</temp>
            <text>${enemy.name} uses Wild Smash for ${enemyDamage}.</text>
            <code>player.hp = player.hp - enemyDamage;</code>
            <else>
              <temp name="enemyDamage" type="int">2</temp>
              <text>${enemy.name} uses Guard Break for ${enemyDamage}.</text>
              <code>player.hp = player.hp - enemyDamage;</code>
            </else>
          </if>
          <text>After enemy action: ${player.name} hp=${player.hp}, ${enemy.name} hp=${enemy.hp}</text>
        </else>
      </if>
    </while>

    <text>Battle ended in ${rounds} rounds.</text>
    <return/>
  </script>
</module>
