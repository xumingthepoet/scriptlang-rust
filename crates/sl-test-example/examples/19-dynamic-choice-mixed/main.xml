<module name="main" default_access="public">
  <script name="main">
    <temp name="candidates" type="int[]">[2, 3]</temp>

    <choice text="Pick">
      <option text="Static">
        <text>S</text>
      </option>

      <dynamic-options array="candidates" item="candidate" index="slot">
        <option text="D-${candidate}-${slot}" when="candidate > 2">
          <text>D ${candidate}/${slot}</text>
        </option>
      </dynamic-options>

      <option text="Tail">
        <text>T</text>
      </option>
    </choice>
  </script>
</module>
