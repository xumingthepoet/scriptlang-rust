<!-- import lib from lib.xml -->
<module name="main" export="script:main;function:run,from_code">
  <function name="run" args="int:x" return_type="int">
    let step = *lib.add1;
    let v = invoke(step, [x]);
    let mul = *lib.times2;
    return invoke(mul, [v]);
  </function>
  <function name="from_code" args="int:x" return_type="int">
    let add = *lib.add1;
    return main.run(x) + invoke(add, [x]);
  </function>
  <script name="main">
    <temp name="value" type="int">0</temp>
    <temp name="addFn" type="function">*lib.add1</temp>
    <code>value = main.from_code(3);</code>
    <code>value = invoke(addFn, [value]);</code>
    <text>${value}</text>
  </script>
</module>
