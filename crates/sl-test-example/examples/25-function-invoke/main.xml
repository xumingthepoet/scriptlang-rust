<!-- import lib from lib.xml -->
<module name="main" default_access="public">
  <function name="run" access="public" args="int:x" return="int:out">
    let step = *lib.add1;
    let v = invoke(step, [x]);
    let mul = *lib.times2;
    out = invoke(mul, [v]);
  </function>
  <function name="from_code" access="public" args="int:x" return="int:out">
    let add = *lib.add1;
    out = main.run(x) + invoke(add, [x]);
  </function>
  <script name="main">
    <temp name="value" type="int">0</temp>
    <temp name="addFn" type="function">*lib.add1</temp>
    <code>value = main.from_code(3);</code>
    <code>value = invoke(addFn, [value]);</code>
    <text>${value}</text>
  </script>
</module>
