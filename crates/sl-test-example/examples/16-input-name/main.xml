<module name="main" default_access="public">
<script name="main">
  <temp name="heroName" type="string">"Traveler"</temp>
  <input var="heroName" text="Name your hero"/>
  <text>Hero: ${heroName}</text>

  <temp name="guildName" type="string">"Nameless Guild"</temp>
  <code>guildName = guildName + " Mk2";</code>
  <input var="guildName" text="Name your guild"/>
  <text>Guild: ${guildName}</text>
</script>
</module>
