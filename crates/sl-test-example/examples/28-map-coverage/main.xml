<module name="main" default_access="public">
  <enum name="Status">
    <member name="Active"/>
    <member name="Inactive"/>
  </enum>

  <var name="wallet" type="#{int}">#{gold: 5}</var>

  <function name="boostCopy" args="#{int}:source,int:delta" returnType="#{int}">
    let out = source;
    out["hp"] = out["hp"] + delta;
    return out;
  </function>

  <script name="boostByRef" args="ref:#{int}:stats">
    <code>stats["hp"] = stats["hp"] + 5;</code>
    <return/>
  </script>

  <script name="main">
    <temp name="stats" type="#{int}">#{hp: 10, mp: 2}</temp>
    <temp name="statusMap" type="#{Status=>int}">#{Active: 7, Inactive: 2}</temp>
    <temp name="statusKey" type="Status">Status.Active</temp>
    <temp name="nested" type="#{#{int}}">#{bag: #{apple: 1}}</temp>
    <temp name="slots" type="#{int[]}">#{line: [1, 2]}</temp>

    <text>hp0=${stats["hp"]}</text>
    <code>stats["hp"] = stats["hp"] + 3;</code>
    <text>hp1=${stats["hp"]}</text>

    <code>let key = "hp"; stats[key] = stats[key] + 2;</code>
    <text>hp2=${stats["hp"]}</text>

    <if when="stats['hp'] > 10">
      <text>if-ok</text>
      <else>
        <text>if-bad</text>
      </else>
    </if>

    <choice text="Map gate">
      <option text="Proceed" when="stats['hp'] > 10">
        <call script="@boostByRef" args="ref:stats"/>
        <text>choice-ok</text>
      </option>
    </choice>

    <code>stats = boostCopy(stats, 4);</code>
    <text>hp3=${stats["hp"]}</text>
    <text>status0=${statusMap[Status.Inactive]}</text>
    <code>statusMap[statusKey] = statusMap[statusKey] + 5;</code>
    <text>status1=${statusMap["Active"]}</text>

    <text>gold0=${wallet["gold"]}</text>
    <code>wallet["gold"] = wallet["gold"] + stats["mp"];</code>
    <text>gold1=${wallet["gold"]}</text>
    <code>wallet.gold = wallet.gold + 1;</code>
    <text>gold2=${wallet.gold}</text>

    <code>nested["bag"]["apple"] = nested["bag"]["apple"] + 2;</code>
    <text>apple=${nested["bag"]["apple"]}</text>

    <code>slots["line"].push(3);</code>
    <text>slot3=${slots["line"][2]}</text>
  </script>
</module>
