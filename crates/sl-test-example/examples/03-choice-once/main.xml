<module name="main" default_access="public">
<script name="main">
  <temp name="round" type="int">0</temp>
  <while when="round  LT  2">
    <choice text="Choose">
      <option text="Pick">
        <code>round = round + 1;</code>
        <text>picked</text>
      </option>
      <option text="Skip">
        <code>round = round + 1;</code>
        <text>skip</text>
      </option>
    </choice>
  </while>
  <text>done</text>
</script>
</module>
