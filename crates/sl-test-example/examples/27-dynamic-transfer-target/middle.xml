<!-- import end from end.xml -->
<module name="middle" export="script:middle;function:pickReturnTarget">
  <function name="pickReturnTarget" args="script:current" return_type="script">
    return current;
    if current == @end.end {
      return @end.end;
    }
  </function>

  <script name="middle">
    <temp name="returnTarget" type="script">@middle.middle</temp>
    <code>returnTarget = pickReturnTarget(@end.end);</code>
    <text>middle</text>
    <return script="returnTarget"/>
  </script>
</module>
