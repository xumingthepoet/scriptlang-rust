<!-- import end from end.xml -->
<module name="middle" export="script:middle;function:pickGotoTarget">
  <function name="pickGotoTarget" args="script:current" return_type="script">
    return current;
    if current == @end.end {
      return @end.end;
    }
  </function>

  <script name="middle">
    <temp name="gotoTarget" type="script">@middle.middle</temp>
    <code>gotoTarget = pickGotoTarget(@end.end);</code>
    <text>middle</text>
    <goto script="gotoTarget"/>
  </script>
</module>
