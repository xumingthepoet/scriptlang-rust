<!-- import end from end.xml -->
<module name="middle" default_access="public">
  <function name="pickReturnTarget" args="script:current" return="script:next">
    next = current;
    if current == @end.end {
      next = @end.end;
    }
  </function>

  <script name="middle">
    <temp name="returnTarget" type="script">@middle.middle</temp>
    <code>returnTarget = pickReturnTarget(@end.end);</code>
    <text>middle</text>
    <return script="returnTarget"/>
  </script>
</module>
