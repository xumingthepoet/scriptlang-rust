<!-- import middle from middle.xml -->
<module name="main" export="script:main;function:pickGotoTarget">
  <function name="pickGotoTarget" return_type="script">
    return @middle.middle;
  </function>

  <script name="main">
    <temp name="gotoTarget" type="script">@main.main</temp>
    <code>gotoTarget = pickGotoTarget();</code>
    <text>before</text>
    <goto script="gotoTarget"/>
  </script>
</module>
