<module name="main" export="script:main">
<script name="main">
  <text>Scenario 09: random builtin</text>
  <temp name="weatherRoll" type="int">random(100)</temp>
  <text>weather roll=${weatherRoll}</text>
  <choice text="Pick action (rng=${random(10)})">
    <option text="Attack (rng=${random(6)})">
      <temp name="damage" type="int">random(4) + 1</temp>
      <text>attack damage=${damage}</text>
    </option>
    <option text="Defend (rng=${random(6)})">
      <temp name="guard" type="int">random(3) + 1</temp>
      <text>guard=${guard}</text>
    </option>
  </choice>
  <text>done</text>
</script>
</module>
