<module name="main" export="script:main">
<script name="main">
  <temp name="hp" type="int">10</temp>
  <text>before ${hp}</text>
  <choice text="Choose">
    <option text="Heal">
      <code>hp = hp + 5;</code>
    </option>
    <option text="Hit">
      <code>hp = hp - 2;</code>
    </option>
  </choice>
  <text>after ${hp}</text>
</script>
</module>
