<module name="main" default_access="public">
<script name="main">
  <temp name="arr1" type="int[]">[1]</temp>
  <temp name="arr2" type="int[]">[10]</temp>
  <choice text="Outer">
    <dynamic-options array="arr1" item="it" index="i">
      <option text="${it}-${i}">
        <choice text="Inner">
          <dynamic-options array="arr2" item="it" index="i">
            <option text="${it}-${i}">
              <text>inner ${it}-${i}</text>
            </option>
          </dynamic-options>
        </choice>
        <text>outer ${it}-${i}</text>
      </option>
    </dynamic-options>
  </choice>
</script>
</module>
