<module name="main" export="script:main">
  <script name="main">
    <temp name="outerCandidates" type="int[]">[1]</temp>
    <temp name="innerCandidates" type="int[]">[10]</temp>

    <choice text="Outer">
      <dynamic-options array="outerCandidates" item="outerItem" index="outerIndex">
        <option text="${outerItem}-${outerIndex}">
          <choice text="Inner">
            <dynamic-options array="innerCandidates" item="innerItem" index="innerIndex">
              <option text="${innerItem}-${innerIndex}">
                <text>inner ${innerItem}-${innerIndex}</text>
              </option>
            </dynamic-options>
          </choice>
          <text>outer ${outerItem}-${outerIndex}</text>
        </option>
      </dynamic-options>
    </choice>
  </script>
</module>
