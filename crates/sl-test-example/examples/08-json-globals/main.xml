<module name="main" default_access="public">
<script name="main">
  <temp name="title" type="string">"Module Globals Demo"</temp>
  <temp name="heroName" type="string">"Rin"</temp>
  <temp name="heroHp" type="int">12</temp>
  <temp name="heroMp" type="int">5</temp>
  <temp name="slot0" type="string">"potion"</temp>
  <temp name="slot0Count" type="int">3</temp>
  <temp name="hardMode" type="boolean">false</temp>
  <text>${title}</text>
  <text>${heroName} hp=${heroHp}, mp=${heroMp}</text>
  <text>slot0=${slot0} x${slot0Count}</text>
  <choice text="Choose">
    <option text="View mode">
      <if when="hardMode">
        <text>hard mode</text>
        <else>
          <text>normal mode</text>
        </else>
      </if>
      <text>done</text>
    </option>
  </choice>
</script>
</module>
