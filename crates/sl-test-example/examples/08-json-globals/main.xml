<module name="main">
<script name="main">
  <var name="title" type="string">"Module Globals Demo"</var>
  <var name="heroName" type="string">"Rin"</var>
  <var name="heroHp" type="int">12</var>
  <var name="heroMp" type="int">5</var>
  <var name="slot0" type="string">"potion"</var>
  <var name="slot0Count" type="int">3</var>
  <var name="hardMode" type="boolean">false</var>
  <text>${title}</text>
  <text>${heroName} hp=${heroHp}, mp=${heroMp}</text>
  <text>slot0=${slot0} x${slot0Count}</text>
  <choice text="Choose">
    <option text="View mode">
      <if when="hardMode">
        <text>hard mode</text>
        <else>
          <text>normal mode</text>
        </else>
      </if>
      <text>done</text>
    </option>
  </choice>
</script>
</module>
