<module name="shared" default_access="public">
  <type name="CustomType">
    <field name="value" type="int"/>
  </type>

  <function name="add" args="int:base,shared.CustomType:item" returnType="int">
    return base + item.value;
  </function>

  <function name="addWithGameBonus" args="int:base,shared.CustomType:item" returnType="int">
    return add(base, item) + 10;
  </function>
</module>
