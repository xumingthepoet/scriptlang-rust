<module name="m" export="function:fetch">
  <const name="vals" type="string[]" format="xml">
    <item>"ok"</item>
  </const>

  <module name="labels" export="const:x">
    <const name="x" type="string">"ok"</const>
  </module>

  <module name="navigation" export="function:get">
    <function name="get" return_type="string">
      for v in vals {
        return labels.x + "-" + v;
      }
      return labels.x;
    </function>
  </module>

  <function name="fetch" return_type="string">
    return navigation.get();
  </function>
</module>
