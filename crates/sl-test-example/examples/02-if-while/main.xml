<module name="main" export="script:main">
<script name="main">
  <temp name="hp" type="int">3</temp>
  <if when="hp > 2">
    <text>strong</text>
    <else>
      <text>weak</text>
    </else>
  </if>
  <while when="hp > 0">
    <code>hp = hp - 1;</code>
  </while>
  <text>hp=${hp}</text>
  <end/>
</script>
</module>
