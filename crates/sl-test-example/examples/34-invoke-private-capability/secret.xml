<module name="secret" export="function:issue_private_ref,open">
  <function name="hidden" args="int:x" return_type="int">
    return x + 10;
  </function>

  <function name="issue_private_ref" return_type="function">
    let fn_ref = *hidden;
    return fn_ref;
  </function>

  <function name="open" args="int:a,int:b" return_type="int">
    return a + b;
  </function>
</module>
