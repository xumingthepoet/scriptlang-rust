<!-- import math from nested/math.xml -->
<module name="shared" default_access="public">
  <type name="Player">
    <field name="name" type="string"/>
    <field name="power" type="int"/>
  </type>
  <function name="greet" args="string:name" return_type="string">
    return math.label(name, 2) + " @recursive";
  </function>
</module>
