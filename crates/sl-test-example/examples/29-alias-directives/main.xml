<!-- import ids from ids.xml -->
<!-- import templates from templates.xml -->
<!-- import calc from calc.xml -->
<!-- alias ids.LocationId -->
<!-- alias templates.RouteNode as Node -->
<!-- alias templates.seed_nodes as seed_nodes -->
<!-- alias templates.seed_distance as seed_distance -->
<!-- alias templates.routes_by_start as routes_by_start -->
<module name="main" export="script:main,boost_home,append_port,emit_report">
  <script name="main">
    <temp name="nodes" type="Node[]">seed_nodes</temp>
    <temp name="distance_map" type="#{LocationId=>int}">seed_distance</temp>
    <temp name="home_routes" type="Node[]">routes_by_start[LocationId.Home]</temp>

    <text>home.routes=${home_routes.len}</text>

    <call script="@main.boost_home" args="ref:distance_map"/>
    <call script="@main.append_port" args="ref:nodes"/>
    <call script="@main.emit_report" args="nodes,distance_map"/>
    <call script="@calc.show_total" args="nodes,distance_map"/>
    <call script="@templates.echo_seed"/>
    <end/>
  </script>

  <script name="boost_home" kind="call" args="ref:#{LocationId=>int}:distance_map">
    <code>distance_map[LocationId.Home] = distance_map[LocationId.Home] + 3;</code>
    <return/>
  </script>

  <script name="append_port" kind="call" args="ref:Node[]:nodes">
    <code>nodes.push(#{id: LocationId.Port, terrain: ids.Terrain.Sea, coord: #{x: 9, y: 1}});</code>
    <return/>
  </script>

  <script name="emit_report" kind="call" args="Node[]:nodes,#{LocationId=>int}:distance_map">
    <text>nodes=${nodes.len}</text>
    <text>home=${distance_map[LocationId.Home]}</text>
    <text>port=${calc.distanceOf(distance_map, LocationId.Port)}</text>
    <return/>
  </script>
</module>
