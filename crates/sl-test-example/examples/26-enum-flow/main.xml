<!-- import ids from ids.xml -->
<!-- import target from target.xml -->
<module name="main" export="script:main">
  <script name="main">
    <choice text="pick location">
      <option text="toA">
        <return script="@target.route" args="ids.LocationId.A"/>
      </option>
      <option text="toB">
        <return script="@target.route" args="ids.LocationId.B"/>
      </option>
    </choice>
  </script>
</module>
