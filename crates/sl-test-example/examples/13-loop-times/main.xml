<module name="main" export="script:main">
<script name="main">
  <temp name="i" type="int">0</temp>
  <temp name="times" type="int">3</temp>

  <loop times="times">
    <code>i = i + 1;</code>
    <if when="i == 2"><continue/></if>
    <if when="i == 3"><break/></if>
    <text>tick-${i}</text>
  </loop>

  <text>done-${i}</text>
</script>
</module>
