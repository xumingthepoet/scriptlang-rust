<module name="shared" default_access="public">
  <type name="CustomType">
    <field name="value" type="int"/>
  </type>

  <function name="add" args="int:a1,shared.CustomType:a2" return="int:b2">
    b2 = a1 + a2.value;
  </function>

  <function name="addWithGameBonus" args="int:a1,shared.CustomType:a2" return="int:b2">
    b2 = a1 + a2.value + 10;
  </function>
</module>
